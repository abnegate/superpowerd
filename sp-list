#!/bin/bash

# List superpowerd tmux sessions with repo info.
#
# Usage:
#   sp-list

WORKSPACE="${SUPERPOWERD_WORKSPACE:-$HOME/Local}"

if ! tmux ls &>/dev/null; then
  echo "No tmux sessions running."
  exit 0
fi

printf "\033[1m%-15s %-30s %-10s %s\033[0m\n" "SESSION" "BRANCH" "STATUS" ""

tmux ls -F '#{session_name}:#{session_attached}' | sort | while IFS=: read -r name attached; do
  dir="$WORKSPACE/$name"
  branch="-"
  status="-"
  if [[ -d "$dir/.git" ]]; then
    branch=$(git -C "$dir" symbolic-ref --short HEAD 2>/dev/null || echo "-")
    dirty=$(git -C "$dir" status --porcelain 2>/dev/null | head -1)
    [[ -n "$dirty" ]] && status="dirty" || status="clean"
  fi
  label=""
  [[ "$attached" -gt 0 ]] && label="(attached)"
  printf "%-15s %-30s %-10s %s\n" "$name" "$branch" "$status" "$label"
done
