#!/bin/bash
# apiKeyHelper script for Claude Code.
# Outputs the active account's OAuth access token.
# Called by Claude Code before every API request (when TTL=0).
#
# To rotate accounts: update data/active-token
# Claude picks up the new token on the very next API call.

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
TOKEN_FILE="$SCRIPT_DIR/../data/active-token"

if [ -f "$TOKEN_FILE" ]; then
  cat "$TOKEN_FILE"
else
  # Fall back to keychain
  security find-generic-password -s "Claude Code-credentials" -w 2>/dev/null | \
    node -e "process.stdout.write(JSON.parse(require('fs').readFileSync('/dev/stdin','utf8')).claudeAiOauth.accessToken)" 2>/dev/null
fi
