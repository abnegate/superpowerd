#!/bin/bash
# Rotate to the next Claude account.
#
# Seamless flow — no restart, no browser, no interruption:
#   1. Write the next account's OAuth token to data/active-token
#   2. Claude Code's apiKeyHelper reads this file on the next API call
#   3. Every running agent picks up the new account automatically
#
# Usage:
#   rotate              # Next account
#   rotate <email>      # Specific account
#   rotate --status     # Show current
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_DIR="$(dirname "$SCRIPT_DIR")"
DATA_DIR="$PROJECT_DIR/data"
STATE_FILE="$DATA_DIR/state.json"
ACCOUNTS_FILE="$PROJECT_DIR/accounts.conf"
TOKENS_FILE="$DATA_DIR/tokens.json"
ACTIVE_TOKEN="$DATA_DIR/active-token"
LOG_FILE="$DATA_DIR/rotate.log"

mkdir -p "$DATA_DIR"

log() {
  local msg="[$(date -u +%Y-%m-%dT%H:%M:%SZ)] $1"
  echo "$msg"
  echo "$msg" >> "$LOG_FILE"
}

notify() {
  osascript -e "display notification \"$1\" with title \"Superpowerd\"" 2>/dev/null \
    || notify-send "Superpowerd" "$1" 2>/dev/null \
    || true
}

load_accounts() {
  local accounts=()
  while IFS= read -r line; do
    [[ -z "$line" || "$line" == \#* ]] && continue
    accounts+=("$line")
  done < "$ACCOUNTS_FILE"
  echo "${accounts[@]}"
}

if [[ ! -f "$STATE_FILE" ]]; then
  echo '{"current": 0}' > "$STATE_FILE"
fi

if [[ ! -f "$ACCOUNTS_FILE" ]]; then
  echo "Error: $ACCOUNTS_FILE not found. Copy accounts.conf.example to accounts.conf"
  exit 1
fi
ACCOUNTS=($(load_accounts))
TOTAL=${#ACCOUNTS[@]}

get_current() {
  node -e "console.log(require('$STATE_FILE').current)"
}

update_state() {
  node -e "
    var fs = require('fs');
    var state = JSON.parse(fs.readFileSync('$STATE_FILE', 'utf8'));
    state.current = $1;
    state.email = '$2';
    state.timestamp = new Date().toISOString();
    fs.writeFileSync('$STATE_FILE', JSON.stringify(state, null, 2) + '\n');
  "
}

CURRENT=$(get_current)
CURRENT_EMAIL=${ACCOUNTS[$CURRENT]}

if [[ "${1:-}" == "--status" ]]; then
  echo "Current: $CURRENT_EMAIL (index $CURRENT of $TOTAL)"
  echo "Accounts:"
  for i in "${!ACCOUNTS[@]}"; do
    marker=""
    [[ "$i" == "$CURRENT" ]] && marker=" <-- active"
    echo "  [$i] ${ACCOUNTS[$i]}$marker"
  done
  echo ""
  node "$SCRIPT_DIR/tokens.js" list 2>/dev/null || true
  claude auth status 2>/dev/null || echo "(CLI not authenticated)"
  exit 0
fi

# Determine next account
if [[ -n "${1:-}" ]]; then
  NEXT_INDEX=-1
  for i in "${!ACCOUNTS[@]}"; do
    [[ "${ACCOUNTS[$i]}" == "$1" ]] && NEXT_INDEX=$i
  done
  if [[ "$NEXT_INDEX" == "-1" ]]; then
    echo "Account not found: $1"
    echo "Available: ${ACCOUNTS[*]}"
    exit 1
  fi
else
  NEXT_INDEX=$(( (CURRENT + 1) % TOTAL ))
fi

NEXT_EMAIL=${ACCOUNTS[$NEXT_INDEX]}

if [[ "$CURRENT" == "$NEXT_INDEX" ]]; then
  log "Already on $CURRENT_EMAIL"
  exit 0
fi

log "=== Rotating: $CURRENT_EMAIL -> $NEXT_EMAIL ==="

# Step 1: Capture current account's tokens (in case they refreshed)
log "Step 1: Saving current tokens"
node "$SCRIPT_DIR/tokens.js" capture 2>&1 | while read -r line; do log "  $line"; done

# Step 2: Get the next account's token
NEXT_TOKEN=$(node -e "
  var store = {};
  try { store = JSON.parse(require('fs').readFileSync('$TOKENS_FILE', 'utf8')); } catch {}
  var token = store['$NEXT_EMAIL'];
  if (token && token.accessToken) {
    process.stdout.write(token.accessToken);
  }
" 2>/dev/null || true)

if [[ -z "$NEXT_TOKEN" ]]; then
  log "No stored token for $NEXT_EMAIL — authenticating via browser"
  notify "Authenticating $NEXT_EMAIL..."

  # Full browser auth flow (first time only)
  claude auth logout 2>/dev/null || true
  node "$SCRIPT_DIR/browser-auth.js" login "$NEXT_EMAIL" 2>&1 | while read -r line; do log "  $line"; done
  node "$SCRIPT_DIR/tokens.js" capture 2>&1 | while read -r line; do log "  $line"; done

  NEXT_TOKEN=$(node -e "
    var store = JSON.parse(require('fs').readFileSync('$TOKENS_FILE', 'utf8'));
    process.stdout.write(store['$NEXT_EMAIL'].accessToken);
  " 2>/dev/null || true)
fi

if [[ -z "$NEXT_TOKEN" ]]; then
  log "ERROR: Could not obtain token for $NEXT_EMAIL"
  exit 1
fi

# Step 3: Write the token — this is the actual rotation
# Claude's apiKeyHelper reads this file on the next API call
log "Step 2: Swapping active token"
printf '%s' "$NEXT_TOKEN" > "$ACTIVE_TOKEN"
chmod 600 "$ACTIVE_TOKEN"

# Step 4: Update state
log "Step 3: State update"
update_state "$NEXT_INDEX" "$NEXT_EMAIL"

log "=== Now using: $NEXT_EMAIL ==="
notify "Now using $NEXT_EMAIL"
echo ""
echo "Switched to: $NEXT_EMAIL"
echo "All running agents will use the new account on their next API call."
