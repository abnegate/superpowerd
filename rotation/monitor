#!/bin/bash
# Monitor Claude Code debug logs for rate limits and auto-rotate accounts.
# Usage:
#   monitor              # Foreground
#   monitor --daemon     # Background
#   monitor --stop       # Stop
#   monitor --status     # Check
set -o pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_DIR="$(dirname "$SCRIPT_DIR")"
DATA_DIR="$PROJECT_DIR/data"
PID_FILE="$DATA_DIR/monitor.pid"
LOG_FILE="$DATA_DIR/monitor.log"
COOLDOWN=300
DEBUG_DIR="$HOME/.claude/debug"

mkdir -p "$DATA_DIR"

log() {
  local msg="[$(date -u +%Y-%m-%dT%H:%M:%SZ)] $1"
  echo "$msg"
  echo "$msg" >> "$LOG_FILE"
}

case "${1:-}" in
  --daemon)
    if [[ -f "$PID_FILE" ]] && kill -0 "$(cat "$PID_FILE")" 2>/dev/null; then
      echo "Already running (PID $(cat "$PID_FILE"))"
      exit 1
    fi
    nohup "$0" >> "$LOG_FILE" 2>&1 &
    echo "$!" > "$PID_FILE"
    echo "Monitor started (PID $!)"
    echo "Log: $LOG_FILE"
    exit 0
    ;;
  --stop)
    if [[ -f "$PID_FILE" ]]; then
      PID=$(cat "$PID_FILE")
      if kill -0 "$PID" 2>/dev/null; then
        kill "$PID"
        rm -f "$PID_FILE"
        echo "Stopped (PID $PID)"
      else
        rm -f "$PID_FILE"
        echo "Not running (stale PID cleaned)"
      fi
    else
      echo "Not running"
    fi
    exit 0
    ;;
  --status)
    if [[ -f "$PID_FILE" ]] && kill -0 "$(cat "$PID_FILE")" 2>/dev/null; then
      echo "Running (PID $(cat "$PID_FILE"))"
      tail -5 "$LOG_FILE" 2>/dev/null
    else
      echo "Not running"
    fi
    exit 0
    ;;
esac

PATTERNS="status=429|Rate limited|rate_limit|usage.*limit|limit.*reached|limit.*exceeded|too many requests|overloaded|status=529|capacity"

LAST_ROTATION=0

should_rotate() {
  local now
  now=$(date +%s)
  [[ $((now - LAST_ROTATION)) -ge $COOLDOWN ]]
}

do_rotate() {
  LAST_ROTATION=$(date +%s)
  log "!!! Rate limit detected — rotating"
  "$SCRIPT_DIR/rotate" 2>&1 | while read -r line; do log "  [rotate] $line"; done
  log "Cooldown: ${COOLDOWN}s"
}

cleanup() {
  log "Shutting down"
  rm -f "$PID_FILE"
  jobs -p | xargs -r kill 2>/dev/null || true
  exit 0
}
trap cleanup SIGTERM SIGINT

echo $$ > "$PID_FILE"
log "Monitor started (cooldown: ${COOLDOWN}s)"

# Watch ALL recently modified debug logs (last 60 min), not just one
TAIL_PIDS=()

restart_watchers() {
  # Kill existing watchers
  for pid in "${TAIL_PIDS[@]}"; do
    kill "$pid" 2>/dev/null || true
  done
  wait 2>/dev/null || true
  TAIL_PIDS=()

  # Find debug logs modified in the last 60 minutes
  ACTIVE_LOGS=$(find "$DEBUG_DIR" -name "*.txt" -mmin -60 2>/dev/null || true)

  if [[ -z "$ACTIVE_LOGS" ]]; then
    # Fall back to most recent
    ACTIVE_LOGS=$(ls -t "$DEBUG_DIR"/*.txt 2>/dev/null | head -1)
  fi

  if [[ -z "$ACTIVE_LOGS" ]]; then
    log "No debug logs found"
    return
  fi

  local count=0
  for logfile in $ACTIVE_LOGS; do
    tail -n 0 -f "$logfile" 2>/dev/null | while read -r line; do
      if echo "$line" | grep -qiE "$PATTERNS"; then
        if echo "$line" | grep -q "client_data.*429"; then
          continue
        fi
        log "Signal [$(basename "$logfile" .txt | cut -c1-8)]: $(echo "$line" | head -c 200)"
        if should_rotate; then
          do_rotate
        else
          log "In cooldown, skipping"
        fi
      fi
    done &
    TAIL_PIDS+=($!)
    count=$((count + 1))
  done
  log "Watching $count debug log(s)"
}

restart_watchers

# Refresh watchers every 60 seconds to pick up new debug logs
while true; do
  sleep 60
  # Check if any watcher died
  ALIVE=0
  for pid in "${TAIL_PIDS[@]}"; do
    kill -0 "$pid" 2>/dev/null && ALIVE=$((ALIVE + 1))
  done
  # Refresh if watchers died or new logs appeared
  NEW_COUNT=$(find "$DEBUG_DIR" -name "*.txt" -mmin -60 2>/dev/null | wc -l | tr -d ' ')
  if [[ "$ALIVE" -lt "${#TAIL_PIDS[@]}" ]] || [[ "$NEW_COUNT" -ne "${#TAIL_PIDS[@]}" ]]; then
    log "Refreshing watchers (alive=$ALIVE, logs=$NEW_COUNT)"
    restart_watchers
  fi
done
