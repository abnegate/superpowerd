#!/bin/bash
# Monitor Claude Code session files for rate limits and auto-rotate accounts.
# Usage:
#   monitor              # Foreground
#   monitor --daemon     # Background
#   monitor --stop       # Stop
#   monitor --status     # Check
set -o pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_DIR="$(dirname "$SCRIPT_DIR")"
DATA_DIR="$PROJECT_DIR/data"
PID_FILE="$DATA_DIR/monitor.pid"
LOG_FILE="$DATA_DIR/monitor.log"
COOLDOWN=300
PROJECTS_DIR="$HOME/.claude/projects"

mkdir -p "$DATA_DIR"

log() {
  echo "[$(date -u +%Y-%m-%dT%H:%M:%SZ)] $1" >> "$LOG_FILE"
}

case "${1:-}" in
  --daemon)
    if [ -f "$PID_FILE" ] && kill -0 "$(cat "$PID_FILE")" 2>/dev/null; then
      echo "Already running (PID $(cat "$PID_FILE"))"
      exit 1
    fi
    nohup "$0" >> "$LOG_FILE" 2>&1 &
    echo "$!" > "$PID_FILE"
    echo "Monitor started (PID $!)"
    echo "Log: $LOG_FILE"
    exit 0
    ;;
  --stop)
    if [ -f "$PID_FILE" ]; then
      PID=$(cat "$PID_FILE")
      if kill -0 "$PID" 2>/dev/null; then
        kill "$PID"
        rm -f "$PID_FILE"
        echo "Stopped (PID $PID)"
      else
        rm -f "$PID_FILE"
        echo "Not running (stale PID cleaned)"
      fi
    else
      echo "Not running"
    fi
    exit 0
    ;;
  --status)
    if [ -f "$PID_FILE" ] && kill -0 "$(cat "$PID_FILE")" 2>/dev/null; then
      echo "Running (PID $(cat "$PID_FILE"))"
      tail -5 "$LOG_FILE" 2>/dev/null
    else
      echo "Not running"
    fi
    exit 0
    ;;
esac

LAST_ROTATION=0

should_rotate() {
  local now
  now=$(date +%s)
  [ $((now - LAST_ROTATION)) -ge $COOLDOWN ]
}

do_rotate() {
  LAST_ROTATION=$(date +%s)
  log "!!! Rate limit detected — rotating"
  "$SCRIPT_DIR/rotate" 2>&1 | while read -r line; do log "  [rotate] $line"; done
  log "Cooldown: ${COOLDOWN}s"
}

cleanup() {
  log "Shutting down"
  rm -f "$PID_FILE"
  kill 0 2>/dev/null || true
  exit 0
}
trap cleanup SIGTERM SIGINT

echo $$ > "$PID_FILE"
log "Monitor started (cooldown: ${COOLDOWN}s)"

# Watch all active session JSONL files for rate limit errors.
# Rate limits appear as: "isApiErrorMessage":true with text like
# "You've hit your limit" or "Rate limit reached"
TAIL_PIDS=""

start_watchers() {
  # Kill existing watchers
  if [ -n "$TAIL_PIDS" ]; then
    for pid in $TAIL_PIDS; do
      kill "$pid" 2>/dev/null || true
    done
    wait 2>/dev/null || true
  fi
  TAIL_PIDS=""

  # Find session JSONL files modified in the last 30 minutes
  local files
  files=$(find "$PROJECTS_DIR" -maxdepth 2 -name "*.jsonl" -mmin -30 2>/dev/null || true)

  if [ -z "$files" ]; then
    # Fall back to most recently modified
    files=$(find "$PROJECTS_DIR" -maxdepth 2 -name "*.jsonl" 2>/dev/null | xargs ls -t 2>/dev/null | head -5)
  fi

  if [ -z "$files" ]; then
    log "No session files found"
    return
  fi

  local count=0
  for logfile in $files; do
    tail -n 0 -f "$logfile" 2>/dev/null | while read -r line; do
      # Check for API error messages indicating rate limits
      if echo "$line" | grep -q '"isApiErrorMessage":true'; then
        if echo "$line" | grep -qiE "hit your limit|rate.limit|limit.*reached|exceeded"; then
          log "Signal [$(basename "$(dirname "$logfile")" | cut -c1-12)]: rate limit detected"
          if should_rotate; then
            do_rotate
          else
            log "In cooldown, skipping"
          fi
        fi
      fi
    done &
    TAIL_PIDS="$TAIL_PIDS $!"
    count=$((count + 1))
  done
  log "Watching $count session file(s)"
}

start_watchers

# Refresh watchers every 60 seconds to pick up new sessions
while true; do
  sleep 60

  # Count alive watchers
  ALIVE=0
  for pid in $TAIL_PIDS; do
    kill -0 "$pid" 2>/dev/null && ALIVE=$((ALIVE + 1))
  done

  # Count current active session files
  NEW_COUNT=$(find "$PROJECTS_DIR" -maxdepth 2 -name "*.jsonl" -mmin -30 2>/dev/null | wc -l | tr -d ' ')

  # Refresh if watchers died or session count changed
  CURRENT_COUNT=$(echo "$TAIL_PIDS" | wc -w | tr -d ' ')
  if [ "$ALIVE" -lt "$CURRENT_COUNT" ] || [ "$NEW_COUNT" -ne "$CURRENT_COUNT" ]; then
    log "Refreshing watchers (alive=$ALIVE, sessions=$NEW_COUNT)"
    start_watchers
  fi
done
