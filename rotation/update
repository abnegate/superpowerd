#!/bin/bash
# Self-update superpowerd from git and restart services.
# Usage:
#   update              # Pull latest + restart
#   update --check      # Check for updates without applying
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_DIR="$(dirname "$SCRIPT_DIR")"

log() {
  echo "[$(date -u +%Y-%m-%dT%H:%M:%SZ)] $1"
}

cd "$PROJECT_DIR"

# Check for updates
LOCAL=$(git rev-parse HEAD 2>/dev/null)
git fetch origin main --quiet 2>/dev/null
REMOTE=$(git rev-parse origin/main 2>/dev/null)

if [[ "$LOCAL" == "$REMOTE" ]]; then
  log "Already up to date (${LOCAL:0:7})"
  exit 0
fi

BEHIND=$(git rev-list HEAD..origin/main --count 2>/dev/null || echo "?")
log "Update available: ${LOCAL:0:7} -> ${REMOTE:0:7} ($BEHIND commits behind)"

if [[ "${1:-}" == "--check" ]]; then
  git log --oneline HEAD..origin/main 2>/dev/null | head -10
  exit 0
fi

# Pull
log "Pulling latest..."
git pull --ff-only origin main 2>&1 || {
  log "ERROR: Pull failed (local changes?). Run: git stash && sp-update"
  exit 1
}

# Rebuild dashboard
log "Rebuilding dashboard..."
cd "$PROJECT_DIR/dashboard"
npm install --silent 2>/dev/null
npx vite build 2>/dev/null

# Re-index sessions (picks up new indexer changes)
log "Re-indexing sessions..."
cd "$PROJECT_DIR"
node rotation/index-sessions.js 2>/dev/null || true

# Restart services
log "Restarting services..."
if [[ "$(uname)" == "Darwin" ]]; then
  for label in com.superpowerd.monitor com.superpowerd.dashboard; do
    PLIST="$HOME/Library/LaunchAgents/${label}.plist"
    if [[ -f "$PLIST" ]]; then
      launchctl unload "$PLIST" 2>/dev/null || true
      launchctl load "$PLIST" 2>/dev/null || true
    fi
  done
else
  systemctl --user restart superpowerd-monitor 2>/dev/null || true
  systemctl --user restart superpowerd-dashboard 2>/dev/null || true
fi

# Sync WezTerm config
if [[ -f "$PROJECT_DIR/wezterm/wezterm.lua" ]]; then
  cp "$PROJECT_DIR/wezterm/wezterm.lua" "$HOME/.config/wezterm/wezterm.lua" 2>/dev/null || true
fi

log "Updated to ${REMOTE:0:7}. Services restarted."
